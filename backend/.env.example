# Copie ce fichier en .env et adapte les valeurs.

# Connexion IB Gateway / TWS
IB_HOST=127.0.0.1
IB_PORT=4002            # 4002 = Gateway PAPER · 4001 = Gateway LIVE · 7497 = TWS paper · 7496 = TWS live
IB_CLIENT_ID=11

# Sécurité de l'API (doit être identique à BACKEND_TOKEN côté Netlify)
BACKEND_TOKEN=change-me-long-random

# CORS — origine de ton site Netlify (ou * en dev)
ALLOWED_ORIGINS=https://aquamarine-chimera-e30880.netlify.app

# Identifiants IBKR pour l'auto-login d'IB Gateway (utilisés par docker-compose)
TWS_USERID=ton_user_ibkr
TWS_PASSWORD=ton_mot_de_passe
TRADING_MODE=paper       # paper | live
