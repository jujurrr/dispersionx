{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/navigation/**",
              "handoff/**",
              "handoff/examples/**",
              "ui_kits/**",
              "ui_kits/app/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|size|dot|pulse|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, size, dot, pulse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|pos|neg|warn|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'pos' | 'neg' | 'warn' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BeginnerExplanationBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|style|key|ref|className|style|children)$/]",
        "message": "<BeginnerExplanationBox> doesn't accept that prop. Declared props: title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|disabled|full|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, disabled, full, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline|ghost|danger|success)$/]",
        "message": "<Button> variant must be one of 'primary' | 'outline' | 'ghost' | 'danger' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CorrelationGauge'] > JSXAttribute > JSXIdentifier[name!=/^(?:implied|realized|size|key|ref|className|style|children)$/]",
        "message": "<CorrelationGauge> doesn't accept that prop. Declared props: implied, realized, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|action|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, description, action, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|delta|deltaTone|hint|accent|size|glass|animate|style|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: label, value, unit, delta, deltaTone, hint, accent, size, glass, animate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='deltaTone'] > Literal[value!=/^(?:auto|pos|neg|neutral)$/]",
        "message": "<MetricCard> deltaTone must be one of 'auto' | 'pos' | 'neg' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<MetricCard> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RiskBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|children|size|key|ref|className|style|children)$/]",
        "message": "<RiskBadge> doesn't accept that prop. Declared props: level, children, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='RiskBadge'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:faible|modéré|élevé|critique)$/]",
        "message": "<RiskBadge> level must be one of 'faible' | 'modéré' | 'élevé' | 'critique'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RiskBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<RiskBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|max|label|size|key|ref|className|style|children)$/]",
        "message": "<ScoreBadge> doesn't accept that prop. Declared props: score, max, label, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<ScoreBadge> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|current|onStepClick|style|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: steps, current, onStepClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WarningPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|children|icon|style|key|ref|className|style|children)$/]",
        "message": "<WarningPanel> doesn't accept that prop. Declared props: tone, title, children, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WarningPanel'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:warn|neg|info|pos)$/]",
        "message": "<WarningPanel> tone must be one of 'warn' | 'neg' | 'info' | 'pos'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
